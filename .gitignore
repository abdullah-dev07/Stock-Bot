# .gitignore

# Ignore all node_modules in any subfolder
**/node_modules/

# Ignore build files
**/build/
**/dist/

# Mac system files
.DS_Store

# Log files
*.log

# Environment files
.env
.env.local
.env.*.local
backend/.env
react-frontend/.env

# Firebase keys
backend/firestore-key.json
backend/firebase-key.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
stockbot_env/
venv/
env/

# Generated docs
DEPLOYMENT.md
DEPLOYMENT_CHECKLIST.md
FIREBASE_SETUP.md
SETUP_GUIDE.md

# IDE
.vscode/
.idea/
*.swp
*.swo